# ==============================================================================
# CamGuard Enterprise - Environment Configuration Example
# ==============================================================================
# Copy this file to .env and configure values for your deployment environment.
# Never commit actual production secrets (.env) to version control.

# --- Backend API & Security Configuration ---
# Secret key used for session signing and Flask security protections
SECRET_KEY=camguard-super-secret-production-key-change-me

# Environment mode: "production" or "development"
ENVIRONMENT=production

# Required API Key for securing configuration modifications (/settings)
# Note: When ENVIRONMENT=production (the default in docker-compose.yml), the app will refuse to boot without an API_KEY set.
API_KEY=your-secure-admin-api-key

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Database Configuration ---
# SQLite default: stored inside docker volume or local path
DATABASE_URL=sqlite:////app/data/health.db
# For PostgreSQL deployment, uncomment below:
# DATABASE_URL=postgresql://camguard_user:secure_password@db_host:5432/camguard_db

# --- Ports & Network ---
# Port on which the Gunicorn / Flask backend binds internally inside Docker
API_PORT=5000
SOCKET_PORT=5000

# Allowed CORS origins for API requests and Socket.IO connections
# In production with Nginx reverse proxy, "*" or the specific domain works
CORS_ALLOWED_ORIGINS=*

# Socket.IO asynchronous mode ("eventlet" for production Gunicorn, "threading" for local dev)
SOCKET_ASYNC_MODE=eventlet

# --- Simulator Configuration ---
# Internal URL of the backend API inside Docker Compose network
BACKEND_URL=http://backend:5000

# Default reporting interval in seconds (can also be dynamically overridden by API settings)
SIMULATOR_INTERVAL=30

# --- Frontend Build Configuration (Vite) ---
# Used during `npm run build` in Dockerfile.frontend
# Leave as empty or "/api" when served behind Nginx reverse proxy
VITE_API_URL=/api
VITE_SOCKET_URL=/
